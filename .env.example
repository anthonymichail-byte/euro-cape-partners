# Copy this file to .env.local for local development.
# In production (Vercel), set these via the Vercel dashboard or `vercel env add` —
# never commit real values to source control.

# Formspree form ID used by app/api/contact/route.ts to forward validated,
# sanitized contact form submissions server-side. Intentionally NOT prefixed
# with NEXT_PUBLIC_: it must never be exposed to the client bundle.
# Get one at https://formspree.io
FORMSPREE_ID=
